# Copy this file to `secrets.properties` (which is gitignored) and fill in your key.
# WARNING: An API key embedded in an APK can be extracted. For real distribution,
# route API calls through your own backend proxy instead of shipping the key.

# Gemini(무료) — OCR 단어 구조화에 사용. 발급: https://aistudio.google.com/apikey
# 카드 등록 없이 구글 로그인만으로 무료 키를 받을 수 있어요.
GEMINI_API_KEY=AIza-your-gemini-key-here

# (선택) OpenAI — 현재 코드는 Gemini를 사용하므로 비워둬도 됩니다.
OPENAI_API_KEY=
